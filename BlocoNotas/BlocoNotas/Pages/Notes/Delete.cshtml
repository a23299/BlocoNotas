@page
@model BlocoNotas.Pages.Notes.DeleteModel
@{
    ViewData["Title"] = "Eliminar Nota";
}

<div class="container py-5 d-flex justify-content-center">
    <div class="col-md-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h2 class="card-title text-danger text-center mb-4">Eliminar Nota</h2>

                <div class="alert alert-warning">
                    <h5 class="alert-heading">Tem a certeza que deseja eliminar esta nota?</h5>
                    <hr />
                    <p><strong>Título:</strong> @Model.Note.Title</p>
                    <p><strong>Conteúdo:</strong> @Model.Note.Content</p>
                </div>

                <form method="post">
                    <div class="d-flex justify-content-between">
                        <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-danger">Confirmar Eliminação</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>