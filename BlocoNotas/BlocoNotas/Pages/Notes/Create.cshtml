@page
@model BlocoNotas.Pages.Notes.CreateModel
@{
    ViewData["Title"] = "Criar Nota";
}

<div class="container py-5 d-flex justify-content-center">
    <div class="col-md-8">
        <div class="card shadow border-0">
            <div class="card-body">
                <h2 class="card-title mb-4 text-primary text-center">Criar Nova Nota</h2>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Note.Title" class="form-label"></label>
                        <input asp-for="Note.Title" class="form-control" required />
                        <span asp-validation-for="Note.Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Note.Content" class="form-label"></label>
                        <textarea asp-for="Note.Content" class="form-control" rows="5"></textarea>
                        <span asp-validation-for="Note.Content" class="text-danger"></span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-page="Index" class="btn btn-outline-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-success">Guardar Nota</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}