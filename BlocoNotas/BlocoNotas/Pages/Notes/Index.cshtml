@page
@model BlocoNotas.Pages.Notes.IndexModel
@{
    ViewData["Title"] = "Minhas Notas";
}

<div class="container py-4">
    <h1 class="mb-4 text-primary">Notas</h1>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <a class="btn btn-success" asp-page="Create">+ Nova Nota</a>

        <div class="d-flex align-items-center gap-2">
            <label class="form-label mb-0 text-nowrap">Filtrar por tag:</label>
            <select asp-for="SelectedTagId" asp-items="@(new SelectList(Model.AvailableTags, "TagId", "Name"))"
                    class="form-select form-select-sm" style="width: auto;"
                    onchange="window.location.href = '?SelectedTagId=' + (this.value || '')">
                <option value="">Todas as tags</option>
            </select>
        </div>
    </div>

    <div class="row gy-4">
        @if (Model.Notes.Count == 0)
        {
            <div class="col-12">
                <p class="text-muted fst-italic">Nenhuma nota encontrada.</p>
            </div>
        }

        @foreach (var note in Model.Notes)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm rounded card-clickable">
                    <div class="card-body" onclick="window.location.href='/Notes/Edit?id=@note.NoteId'">
                        <h5 class="card-title">@note.Title</h5>
                        <p class="card-text text-muted small">Última atualização: @note.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                        <p class="card-text">@(note.Content?.Length > 100 ? note.Content[..100] + "..." : note.Content ?? "")</p>

                        <div class="mt-3">
                            @if (note.NoteTags?.Count > 0)
                            {
                                foreach (var nt in note.NoteTags)
                                {
                                    <span class="badge me-1" style="background-color: @nt.Tag.Color; color: #fff;">@nt.Tag.Name</span>
                                }
                            }
                        </div>
                    </div>

                    <div class="card-footer bg-transparent border-top d-flex flex-wrap gap-1">
                        <a class="btn btn-sm btn-outline-danger" asp-page="Delete" asp-route-id="@note.NoteId"
                           onclick="event.stopPropagation()">Eliminar</a>
                        <a class="btn btn-sm btn-outline-info" asp-page="/NoteShares/Create" asp-route-noteId="@note.NoteId"
                           onclick="event.stopPropagation()">Partilhar</a>

                        <div class="dropdown" onclick="event.stopPropagation()">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button"
                                    data-bs-toggle="dropdown" aria-expanded="false">
                                Gerir Tags
                            </button>
                            <div class="dropdown-menu p-3" style="min-width: 200px;">
                                <form method="post" asp-page-handler="UpdateTags" asp-route-noteId="@note.NoteId"
                                      class="tag-update-form">
                                    @foreach (var tag in Model.AvailableTags)
                                    {
                                        var isChecked = note.NoteTags?.Any(nt => nt.TagFK == tag.TagId) ?? false;
                                        <div class="form-check mb-1">
                                            <input type="checkbox" class="form-check-input tag-checkbox"
                                                   name="tagIds" value="@tag.TagId"
                                                   id="tag_@(note.NoteId)_@tag.TagId"
                                                   @(isChecked ? "checked" : "")
                                                   onchange="this.form.submit()" />
                                            <label class="form-check-label" for="tag_@(note.NoteId)_@tag.TagId">@tag.Name</label>
                                        </div>
                                    }
                                    <hr class="my-2" />
                                    <a asp-page="/Tags/Create" class="btn btn-sm btn-outline-success w-100">+ Criar tag</a>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>