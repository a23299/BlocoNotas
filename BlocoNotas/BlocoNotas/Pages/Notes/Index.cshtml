@page
@model BlocoNotas.Pages.Notes.IndexModel
@{
    ViewData["Title"] = "Minhas Notas";
}

<div class="container py-4">
    <h1 class="mb-4 text-primary">Notas</h1>

    <div class="mb-3">
        <a class="btn btn-success" asp-page="Create">+ Nova Nota</a>
    </div>

    <div class="row gy-4">
        @if (Model.Notes.Count == 0)
        {
            <div class="col-12">
                <p class="text-muted fst-italic">Nenhuma nota encontrada.</p>
            </div>
        }

        @foreach (var note in Model.Notes)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm rounded">
                    <div class="card-body">
                        <h5 class="card-title">@note.Title</h5>
                        <p class="card-text text-muted small">Última atualização: @note.UpdatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                        <p class="card-text">@(note.Content?.Length > 100 ? note.Content[..100] + "..." : note.Content ?? "")</p>

                        <div class="mt-3">
                            @if (note.NoteTags?.Count > 0)
                            {
                                foreach (var nt in note.NoteTags)
                                {
                                    <span class="badge bg-info text-dark me-1">@nt.Tag.Name</span>
                                }
                            }
                        </div>

                        <div class="mt-3 d-flex flex-wrap gap-1">
                            <a class="btn btn-sm btn-outline-primary" asp-page="Edit" asp-route-id="@note.NoteId">Editar</a>
                            <a class="btn btn-sm btn-outline-danger" asp-page="Delete" asp-route-id="@note.NoteId">Eliminar</a>
                            <a class="btn btn-sm btn-outline-info" asp-page="/NoteShares/Create" asp-route-noteId="@note.NoteId">Partilhar</a>
                            <a class="btn btn-sm btn-outline-secondary" asp-page="/Tags/Index" asp-route-noteId="@note.NoteId">Tags</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>