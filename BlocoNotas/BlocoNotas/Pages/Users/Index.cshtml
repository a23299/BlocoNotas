@page
@model BlocoNotas.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Lista de Utilizadores";
}

<div class="container mt-5">
    <h2 class="mb-4 text-primary border-bottom pb-2">Lista de Utilizadores</h2>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-primary text-primary">
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>Email</th>
                    <th>Admin</th>
                    <th class="text-center">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td class="text-truncate" style="max-width:120px;">@user.Id</td>
                        <td>@user.UserName</td>
                        <td>@user.Email</td>
                        <td>
                            @if (Model.IsAdmin[user.Id])
                            {
                                <span class="badge bg-warning text-dark">Admin</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Utilizador</span>
                            }
                        </td>
                        <td class="text-center" style="white-space: nowrap;">
                            <a asp-page="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary me-1">Editar</a>
                            <a asp-page="Details" asp-route-id="@user.Id" class="btn btn-sm btn-outline-info me-1">Detalhes</a>

                            @if (!Model.IsAdmin[user.Id])
                            {
                                <form method="post" asp-page-handler="MakeAdmin" asp-route-id="@user.Id" class="d-inline"
                                      onsubmit="return confirm('Promover este utilizador a Admin?');">
                                    <button type="submit" class="btn btn-sm btn-warning me-1">Dar Admin</button>
                                </form>
                            }

                            <form method="post" asp-page-handler="Delete" asp-route-id="@user.Id" class="d-inline"
                                  onsubmit="return confirm('Tem a certeza que quer eliminar este utilizador?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>