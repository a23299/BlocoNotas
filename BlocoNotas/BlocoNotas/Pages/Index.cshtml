@page
@{
    ViewData["Title"] = "Página Inicial";
}

<div class="container py-5 d-flex flex-column justify-content-center align-items-center" style="min-height: 85vh;">
    <h1 class="display-4 fw-bold text-primary text-center mb-3">
        Bem-vindo ao <span class="text-dark">BlocoNotas</span>
    </h1>

    <p class="lead text-secondary text-center mb-5">
        Organize as suas ideias, tarefas e notas com simplicidade e segurança.
    </p>

    <div class="row w-100 justify-content-center g-4">
        <div class="col-md-5">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body text-center">
                    <h5 class="card-title mb-4">Acesso</h5>
                    <div class="d-grid gap-3">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <a class="btn btn-outline-success btn-lg" asp-page="/Notes/Index">
                                📝 As Minhas Notas
                            </a>
                            <a class="btn btn-success btn-lg" asp-page="/Notes/Create">
                                ➕ Criar Nota
                            </a>
                        }
                        else
                        {
                            <a class="btn btn-outline-success btn-lg" asp-area="Identity" asp-page="/Account/Login">
                                Iniciar Sessão
                            </a>
                            <a class="btn btn-success btn-lg" asp-area="Identity" asp-page="/Account/Register">
                                Criar Conta
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body text-center">
                    <h5 class="card-title mb-4">Funcionalidades</h5>
                    <div class="d-grid gap-3">
                        <a class="btn btn-outline-primary btn-lg" asp-page="/Notes/Index">
                            📝 Notas
                        </a>
                        <a class="btn btn-outline-primary btn-lg" asp-page="/NoteShares/Index">
                            🤝 Notas Partilhadas
                        </a>
                        <a class="btn btn-outline-primary btn-lg" asp-page="/Users/Index">
                            ⚙️ Gerir Utilizadores
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>