@page
@model BlocoNotas.Pages.Tags.IndexModel
@{
    ViewData["Title"] = "Tags";
}

<div class="container py-4">
    <h2 class="mb-4 text-primary">Lista de Tags</h2>

    <div class="mb-3">
        <a asp-page="Create" class="btn btn-success">+ Nova Tag</a>
    </div>

    <div class="row gy-3">
        @if (Model.Tags.Count == 0)
        {
            <div class="col-12">
                <p class="text-muted fst-italic">Nenhuma tag encontrada.</p>
            </div>
        }

        @foreach (var tag in Model.Tags)
        {
            <div class="col-md-4 col-lg-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <span class="badge me-2" style="background-color: @tag.Color; color: #fff;">@tag.Name</span>
                        <div>
                            <a asp-page="Edit" asp-route-id="@tag.TagId" class="btn btn-sm btn-outline-primary me-1">Editar</a>
                            <form method="post" asp-page-handler="Delete" asp-route-id="@tag.TagId" class="d-inline"
                                  onsubmit="return confirm('Tem a certeza que quer eliminar esta tag?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>